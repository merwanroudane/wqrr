\name{wqrr-package}
\alias{wqrr-package}
\alias{wqrr}
\docType{package}
\title{wqrr: Wavelet Quantile Regression Toolbox}
\description{Eight wavelet-quantile estimators in one consistent
interface: Wavelet Quantile Regression, Multivariate WQR, Wavelet
Quantile-on-Quantile Regression with p-values, nonparametric
Causality-in-Quantiles and its wavelet variant, Wavelet Quantile
Mediation and Moderation, Wavelet Quantile Correlation, and a wavelet
nonparametric Quantile Density estimator.}
\section{Main functions}{
\itemize{
  \item \code{\link{wavelet_qr}} - Wavelet Quantile Regression.
  \item \code{\link{multivariate_wqr}} - Multivariate WQR.
  \item \code{\link{wavelet_qqr}} - Wavelet QQR with p-values.
  \item \code{\link{np_quantile_causality}} - Causality-in-Quantiles.
  \item \code{\link{wavelet_np_causality}} - Wavelet variant.
  \item \code{\link{wavelet_mediation}} - Mediation / moderation.
  \item \code{\link{wavelet_quantile_correlation}} - WQC.
  \item \code{\link{wavelet_quantile_density}} - Quantile density.
  \item \code{\link{parula_colors}}, \code{\link{wqrr_colorscales}} -
        MATLAB-style colour palettes.
}
}
\section{See also}{
For plain Quantile-on-Quantile regression see the companion CRAN
package \code{QuantileOnQuantile}.
}
